# OpenAI-compatible model service, LM Studio by default
OPENAI_BASE_URL=http://localhost:5000/v1
OPENAI_API_KEY=lm-studio
OPENAI_MODEL=qwen2/world2

# CapsWriter markdown output file
CAPSWRITER_MARKDOWN_PATH=C:\\path\\to\\CapsWriter\\output.md

# ChatTTS local service
CHATTTS_TTS_URL=http://127.0.0.1:9966/tts
CHATTTS_AUDIO_FOLDER=C:\\path\\to\\ChatTTS\\static\\wavs

# Optional Baidu translate API for Chinese -> English sentiment analysis
BAIDU_TRANSLATE_APP_ID=
BAIDU_TRANSLATE_SECRET_KEY=
